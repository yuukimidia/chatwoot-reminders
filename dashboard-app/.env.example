# URL base do seu n8n (sem barra no final), ex: https://n8n.suaempresa.com.br
N8N_BASE_URL=

# Segredo compartilhado enviado no header X-Webhook-Secret para os webhooks do n8n.
# Gere algo forte, ex: openssl rand -hex 32
N8N_WEBHOOK_SECRET=

# URL do seu Chatwoot, usada só para restringir o frame-ancestors (CSP) do iframe.
CHATWOOT_BASE_URL=https://seu-chatwoot.suaempresa.com.br
